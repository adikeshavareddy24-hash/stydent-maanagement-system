@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background: linear-gradient(120deg, #1d2671, #c33764);
        min-height: 100vh;
    }

    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 90vh;
    }

    .login-card {
        background: #ffffff;
        padding: 35px;
        width: 360px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.25);
    }

        .login-card h2 {
            text-align: center;
            margin-bottom: 25px;
            color: #333;
            font-weight: bold;
        }

    .form-control {
        height: 45px;
        border-radius: 8px;
    }

    .btn-login {
        background: #1d2671;
        color: white;
        font-weight: bold;
        border-radius: 8px;
        height: 45px;
        width: 100%;
    }

        .btn-login:hover {
            background: #c33764;
            color: white;
        }

    .error-msg {
        color: red;
        text-align: center;
        margin-top: 10px;
        font-weight: bold;
    }
</style>

<div class="login-container">
    <div class="login-card">
        <h2>Student Management System</h2>

        <form method="post">
            <div class="form-group">
                <input type="text"
                       name="username"
                       class="form-control"
                       placeholder="Username"
                       required />
            </div>

            <div class="form-group mt-3">
                <input type="password"
                       name="password"
                       class="form-control"
                       placeholder="Password"
                       required />
            </div>

            <button type="submit" class="btn btn-login mt-4">
                Login
            </button>
            <a href="/Account/ForgotPassword">Forgot Password?</a>

        </form>

        @if (ViewBag.Error != null)
        {
            <div class="error-msg">
                @ViewBag.Error
            </div>
        }
    </div>
</div>
<script>
    const form = document.querySelector("form");
    const button = document.querySelector(".btn-login");

    form.addEventListener("submit", function () {
        button.disabled = true;
        button.innerText = "Logging in...";
    });
</script>
