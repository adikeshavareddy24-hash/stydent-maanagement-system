@model IEnumerable<StudentManagementSystem.Models.Course>

@{
    ViewBag.Title = "Courses";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Course Management</h2>
        <a href="/Dashboard/Index" class="btn btn-secondary btn-sm">
            Back to Dashboard
        </a>
    </div>

    <!-- Add Button (Admin Only) -->
    @if (Session["Role"]?.ToString() == "Admin")
    {
        <div class="mb-3">
            <a href="/Course/Create" class="btn btn-primary">
                + Add Course
            </a>
        </div>
    }

    <!-- Course Table -->
    <div class="card shadow-sm">
        <div class="card-body">

            <table class="table table-bordered table-hover text-center align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Course Name</th>
                        <th>Description</th>
                        <th>Duration (Weeks)</th>

                        @if (Session["Role"]?.ToString() == "Admin")
                        {
                            <th>Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td>@c.CourseName</td>
                            <td>@c.Description</td>
                            <td>@c.DurationWeeks</td>

                            @if (Session["Role"]?.ToString() == "Admin")
                            {
                                <td>
                                    <a href="/Course/Edit/@c.CourseId"
                                       class="btn btn-sm btn-warning">
                                        Edit
                                    </a>

                                    <a href="/Course/Delete/@c.CourseId"
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('Are you sure you want to delete this course?')">
                                        Delete
                                    </a>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

</div>
