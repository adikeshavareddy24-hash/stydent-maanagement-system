@using StudentManagementSystem.Models
@{
    ViewBag.Title = "Mark Attendance";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var students = ViewBag.Students as List<Student>;
    var courses = ViewBag.Courses as List<Course>;
}

<div class="container mt-4">

    <div class="card shadow-lg p-4">
        <h3 class="text-center mb-4 text-primary">Mark Attendance</h3>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger text-center">
                @TempData["Error"]
            </div>
        }

        @using (Html.BeginForm("Mark", "Attendance", FormMethod.Post))
        {
            <div class="mb-3">
                <label class="form-label fw-bold">Select Student</label>
                <select name="studentId" class="form-control" required>
                    <option value="">-- Select Student --</option>
                    @foreach (var s in students)
                    {
                        <option value="@s.StudentId">@s.Name</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Select Course</label>
                <select name="courseId" class="form-control" required>
                    <option value="">-- Select Course --</option>
                    @foreach (var c in courses)
                    {
                        <option value="@c.CourseId">@c.CourseName</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Select Date</label>
                <input type="date"
                       name="attendanceDate"
                       class="form-control"
                       min="@DateTime.Today.AddMonths(-12).ToString("yyyy-MM-dd")"
                       max="@DateTime.Today.ToString("yyyy-MM-dd")"
                       required />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Attendance Status</label>
                <select name="isPresent" class="form-control">
                    <option value="true">Present</option>
                    <option value="false">Absent</option>
                </select>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-success">
                    Save Attendance
                </button>
            </div>
        }

        <div class="text-center mt-3">
            <a href="@Url.Action("Index","Dashboard")" class="btn btn-secondary btn-sm">
                ← Back to Dashboard
            </a>
        </div>

    </div>

</div>
