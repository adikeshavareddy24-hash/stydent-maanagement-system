@model StudentManagementSystem.Models.Enrollment

@{
    ViewBag.Title = "Enroll Student";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Enroll Student to Course</h2>
        <a href="/Dashboard/Index" class="btn btn-secondary btn-sm">
            Back to Dashboard
        </a>
    </div>

    <!-- Form Card -->
    <div class="card shadow-sm">
        <div class="card-body">

            @using (Html.BeginForm())
            {
                <div class="mb-3">
                    <label class="form-label fw-bold">Select Student</label>
                    @Html.DropDownListFor(m => m.StudentId,
                        (SelectList)ViewBag.Students,
                        "-- Select Student --",
                        new { @class = "form-select" })
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Select Course</label>
                    @Html.DropDownListFor(m => m.CourseId,
                        (SelectList)ViewBag.Courses,
                        "-- Select Course --",
                        new { @class = "form-select" })
                </div>

                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary">
                        Enroll
                    </button>
                </div>
            }

        </div>
    </div>

</div>
