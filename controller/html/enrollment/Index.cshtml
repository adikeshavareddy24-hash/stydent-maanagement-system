@model IEnumerable<StudentManagementSystem.Models.Enrollment>

@{
    ViewBag.Title = "Enrollments";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Enrollment Management</h2>
        <a href="/Dashboard/Index" class="btn btn-secondary btn-sm">
            Back to Dashboard
        </a>
    </div>

    <!-- Add Enrollment Button -->
    <div class="mb-3">
        <a href="/Enrollment/Create" class="btn btn-primary">
            + Enroll New Student
        </a>
    </div>

    <!-- Enrollment Table -->
    <div class="card shadow-sm">
        <div class="card-body">

            <table class="table table-bordered table-hover text-center align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Student Name</th>
                        <th>Course Name</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in Model)
                    {
                        <tr>
                            <td>@e.Student.Name</td>
                            <td>@e.Course.CourseName</td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

</div>
